# Firebase web config for cloud saves + shareable bakeries.
# Copy this file to `.env` and fill in the values from your Firebase project:
#   Firebase console -> Project settings -> General -> Your apps -> Web app -> SDK config.
# Leave these unset and the game runs in local-only mode (saves to the browser).
#
# These are web client keys and are safe to expose in a front-end build; protect
# your data with Firestore Security Rules, not by hiding these values.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
